@page "/admin/webshop-structures"
@page "/admin/webshop-product-structures"
@page "/admin/product-prices"
@page "/admin/product-tiers"
@page "/admin/product-options"
@page "/admin/price-list-categories"
@page "/admin/manufacturers"
@page "/admin/suppliers"
@page "/admin/delivery-addresses"
@page "/admin/customer-discounts"
@page "/admin/customer-types"
@page "/admin/order-statuses"
@page "/admin/delivery-types"
@page "/admin/product-stock"
@page "/admin/stock-locations"
@page "/admin/payment-methods"
@page "/admin/staff-users"
@page "/admin/user-groups"
@page "/admin/vat-types"
@layout AdminLayout
@attribute [Authorize(Policy = AppPolicies.AdminOrManager)]
@using WebShopABMATIC.Application.Auth
@inject NavigationManager Navigation

<PageTitle>@_title</PageTitle>

<a class="btn btn-outline-secondary btn-sm mb-3" href="/admin"><span class="oi oi-arrow-left"></span> Back to start</a>

<div class="alert alert-secondary">
    <h1 class="h5">@_title</h1>
    <p class="mb-0">List and form screen for <strong>@_entity</strong> will be implemented in the next iteration. Navigation and ports are wired; use <a href="/admin/products">Product</a>, <a href="/admin/customers">Customer</a>, and <a href="/admin/orders">Order</a> for working CRUD/list flows.</p>
</div>

@code {
    private string _title = "Entity";
    private string _entity = "Entity";

    protected override void OnInitialized()
    {
        var path = Navigation.ToBaseRelativePath(Navigation.Uri).TrimEnd('/');
        _entity = path.Split('/').LastOrDefault() ?? "entity";
        _title = string.Join(' ', _entity.Split('-').Select(w => char.ToUpper(w[0]) + w[1..]));
    }
}
