@page "/admin/hub/{HubId}"
@layout AdminLayout
@attribute [Authorize(Policy = AppPolicies.AdminOrManager)]
@using WebShopABMATIC.Application.Auth
@using WebShopABMATIC.Application.Ports
@inject IAdminHubPort HubPort

<PageTitle>@(_hub?.Title ?? "Hub")</PageTitle>

<div class="mb-3">
    <a class="btn btn-outline-secondary btn-sm" href="/admin">
        <span class="oi oi-arrow-left"></span> Back to start
    </a>
</div>

@if (_hub is null)
{
    <p class="text-danger">Hub not found.</p>
}
else
{
    <h1 class="h3 mb-1"><span class="oi @_hub.IconClass"></span> @_hub.Title</h1>
    <p class="text-muted mb-4">@_hub.Subtitle</p>
    <div class="hub-grid">
        @foreach (var card in _hub.Cards)
        {
            <div class="hub-card">
                <div class="entity-tag">@card.Entity</div>
                <h4 class="h5">@card.Title</h4>
                <p class="text-muted flex-grow-1">@card.Description</p>
                <a class="btn btn-outline-primary w-100" href="@card.ListRoute">@card.Title form</a>
            </div>
        }
    </div>
}

@code {
    [Parameter] public string HubId { get; set; } = string.Empty;

    private WebShopABMATIC.Application.Admin.Hubs.AdminHubDefinitionDto? _hub;

    protected override void OnParametersSet() =>
        _hub = HubPort.GetHub(HubId);
}
